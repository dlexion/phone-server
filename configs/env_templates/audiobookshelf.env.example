# Audiobookshelf service-specific configuration.
# Sourced in services/audiobookshelf/run AFTER boot.env,
# so DATA_DIR and AUDIOBOOKSHELF_PORT are already available.

# Port — must match AUDIOBOOKSHELF_PORT in boot.env (Caddy reads that file)
PORT=$AUDIOBOOKSHELF_PORT

# Use Termux system binaries instead of ABS's bundled glibc ffprobe/ffmpeg
FFPROBE_PATH="/data/data/com.termux/files/usr/bin/ffprobe"
FFMPEG_PATH="/data/data/com.termux/files/usr/bin/ffmpeg"

# ABS data directories on the external SSD
# DATA_DIR is set in boot.env to $TERMUX_HOME/server-data/data
CONFIG_PATH="$DATA_DIR/audiobookshelf/config"
METADATA_PATH="$DATA_DIR/audiobookshelf/metadata"
