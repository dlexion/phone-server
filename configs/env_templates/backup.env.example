# Rclone Cloud Backup Configuration
RCLONE_REMOTE="my-cloud-remote" # The name of your rclone remote
REMOTE_ROOT="phone-server-backups" # The root folder on the remote
RETENTION_DAYS="7" # How many days to keep archived backups

# Optional: Extra flags for rclone operations
RCLONE_OPTS="--fast-list"

# Gatus health check tokens for backup jobs
# These are unique tokens for each backup script to report its status.
MEMOS_BACKUP_TOKEN=
SYSTEM_BACKUP_TOKEN=
