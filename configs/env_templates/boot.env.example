# -----------------------------------------------------------------------------
# GLOBAL BOOT & PATH CONFIGURATION
#
# These variables define the core directory structure and are sourced by most
# runit services and scripts. They should not contain secrets.
# -----------------------------------------------------------------------------

# Core Paths
TERMUX_HOME="/data/data/com.termux/files/home"
BIN_DIR="$TERMUX_HOME/bin"
LOG_DIR="$TERMUX_HOME/logs"
DATA_DIR="$TERMUX_HOME/data"
TEMP_DIR="$TERMUX_HOME/temp" # For temporary files, archives, etc.

# -----------------------------------------------------------------------------
# SERVICE DISCOVERY & PORTS
#
# Internal URLs and ports for services, used by dashboards like Glance
# or for inter-service communication.
# -----------------------------------------------------------------------------
# Ports (can be useful for firewall rules or dynamic configs)
ADGUARD_PORT="3000"
GATUS_PORT="8080"
BESZEL_PORT="8090"
MEMOS_PORT="5230"
GLANCE_PORT="8081"
FILEBROWSER_PORT="8085"

ADGUARD_URL="http://127.0.0.1:$ADGUARD_PORT"
GATUS_URL="http://127.0.0.1:$GATUS_PORT"
BESZEL_URL="http://127.0.0.1:$BESZEL_PORT"
MEMOS_URL="http://127.0.0.1:$MEMOS_PORT"

# -----------------------------------------------------------------------------
# SHARED SERVICE CONFIGURATION
#
# Centralized endpoints and identifiers used by multiple services.
# -----------------------------------------------------------------------------

# Gatus API Endpoint for sending health check pings
GATUS_API_URL="$GATUS_URL/api/v1/endpoints"

# Path to the global SSL certificate and key for services that need it (e.g. Caddy)
SSL_CERT_FILE="/path/to/your/cert.pem"
