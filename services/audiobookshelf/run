#!/data/data/com.termux/files/usr/bin/sh
set -a
. "$HOME/phone-server/.secrets/boot.env"
. "$HOME/phone-server/.secrets/audiobookshelf.env"
set +a

# ABS runs inside Debian proot (full glibc — avoids android_ndk_path build issue).
# server-data is bind-mounted at /server-data inside the container.
# Add the audiobooks library pointing to /server-data/files/audiobooks in the ABS UI.
exec proot-distro login debian \
    --bind "$HOME/server-data:/server-data" \
    -- \
    env \
        PORT="$AUDIOBOOKSHELF_PORT" \
        CONFIG_PATH="/server-data/data/audiobookshelf/config" \
        METADATA_PATH="/server-data/data/audiobookshelf/metadata" \
        FFPROBE_PATH="/usr/bin/ffprobe" \
        FFMPEG_PATH="/usr/bin/ffmpeg" \
        HOME=/root \
    node /root/audiobookshelf/index.js \
    >> "${LOG_DIR}/audiobookshelf.log" 2>&1
